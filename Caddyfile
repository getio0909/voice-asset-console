{
	admin off
	auto_https off
}

:8080 {
	encode zstd gzip

	@server path /api/* /healthz /livez /readyz /version
	handle @server {
		reverse_proxy {$VOICEASSET_API_UPSTREAM:http://api:8080}
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	header {
		-Server
		Content-Security-Policy "default-src 'self'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; connect-src 'self'; img-src 'self' data:; media-src 'self' blob:; style-src 'self'; script-src 'self'"
		Permissions-Policy "camera=(), geolocation=(), microphone=()"
		Referrer-Policy "no-referrer"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
	}

	log {
		output stdout
		format json
	}
}
