{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": [
    "eslint.config.js",
    "e2e/**/*.ts",
    "playwright.config.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "types": ["node"]
  }
}
